# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
SESSION_SECRET=change-me-in-production

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://bolt:boltpass@localhost:5432/boltdiy

# ─── Proxy Configuration ──────────────────────────────────────────────────────
# Enable or disable the proxy API
PROXY_ENABLED=false

# Base URL of the upstream AI provider
# Examples:
#   OpenAI:     https://api.openai.com
#   Anthropic:  https://api.anthropic.com
#   Ollama:     http://localhost:11434/v1
#   LM Studio:  http://localhost:1234/v1
PROXY_BASE_URL=

# Provider type: openai | anthropic | ollama | lmstudio | custom
PROXY_PROVIDER=openai

# API key for the upstream provider (leave blank for local providers like Ollama/LM Studio)
PROXY_API_KEY=

# Request timeout in milliseconds (default: 30000)
PROXY_TIMEOUT=30000
